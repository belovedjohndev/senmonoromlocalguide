---
import BaseLayout from "../layouts/BaseLayout.astro";

const contactPhone = "+855 96 388 5424";
const contactPhoneDigits = "855963885424";
const contactEmail = "john@belovedjohndev.com";
const whatsappUrl = `https://wa.me/${contactPhoneDigits}`;
const telegramUrl = `tg://resolve?phone=${contactPhoneDigits}`;
const emailUrl = `mailto:${contactEmail}?subject=Sen%20Monorom%20Local%20Guide%20business%20listing`;
---

<BaseLayout
  title="Submit Your Business | Sen Monorom Local Guide"
  description="Submit owner-confirmed business details for a free listing in the Sen Monorom Local Guide."
>
  <section>
    <div class="container">
      <div class="content-panel page-header">
        <h1>Submit Your Business</h1>
        <p>
          The guide offers a free listing for local businesses in Sen Monorom. New listings are added
          after owner confirmation or field verification so visitors can rely on the details.
        </p>
      </div>

      <div class="content-panel">
        <h2>What to send</h2>
        <p>To request a listing, please share the business details below:</p>
        <ul class="info-list">
          <li>Business name</li>
          <li>Category</li>
          <li>Google Maps location</li>
          <li>Phone</li>
          <li>Facebook page</li>
          <li>Opening hours</li>
          <li>Photos</li>
        </ul>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="cta-panel">
        <h2>Message John to submit your business details.</h2>
        <p>
          Send the details by Telegram or WhatsApp at {contactPhone}, or email {contactEmail}.
        </p>
        <div class="button-row contact-actions">
          <a class="button" href={whatsappUrl}>WhatsApp</a>
          <a class="button-secondary" href={telegramUrl}>Telegram</a>
          <a class="button-secondary" href={emailUrl}>Email John</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
