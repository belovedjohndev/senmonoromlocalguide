---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Motorbike Rentals in Sen Monorom | Sen Monorom Local Guide"
  description="Motorbike rental listings in Sen Monorom are being verified before publication."
>
  <section>
    <div class="container">
      <div class="content-panel page-header">
        <h1>Motorbike Rentals</h1>
        <p>
          Rental information needs to be practical and current, so listings are being verified before
          they are published.
        </p>
      </div>

      <div class="empty-state">
        <h2>Listings are being verified</h2>
        <p>
          Motorbike rental listings are being verified. Local owners can submit details for a free
          listing.
        </p>
        <p>
          Know a local business that should be listed? Send us the business name or Facebook page and
          we will verify it.
        </p>
        <div class="button-row">
          <a class="button" href="/submit-business">Submit a business</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
